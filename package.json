{
  "name": "aso-pcmso-clinica-pierro",
  "version": "1.1.0",
  "description": "Sistema local (offline) para geracao de ASO/PCMSO em PDF - Clinica Pierro",
  "main": "server/index.js",
  "bin": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/ASO-PCMSO-ClinicaPierro.exe"
  },
  "pkg": {
    "scripts": [
      "server/**/*.js"
    ],
    "assets": [
      "views/**/*",
      "public/**/*",
      "node_modules/pdfkit/js/data/**/*",
      "node_modules/es-get-iterator/**/*"
    ]
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "ejs": "^3.1.10",
    "es-get-iterator": "^1.1.3",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
