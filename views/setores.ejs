<% const pageTitle = 'Cadastro de Setores'; %>
<%- include('partials/head', {pageTitle}) %>
<%- include('partials/nav', {pageTitle, active: 'setores'}) %>

<div class="flex justify-between items-end mb-stack-lg">
  <div>
    <h3 class="font-headline-lg text-headline-lg text-on-surface">Lista de Setores</h3>
    <p class="text-on-surface-variant font-body-md text-body-md mt-1">Gerencie os departamentos e áreas de atuação da empresa.</p>
  </div>
  <button class="bg-primary text-white px-6 py-2.5 rounded-lg font-bold flex items-center gap-2 hover:opacity-90 transition-opacity shadow-sm" onclick="abrirModal()">
    <span class="material-symbols-outlined">add</span> Adicionar Setor
  </button>
</div>
<div id="paginacao-setores"></div>

<div class="mb-4 relative max-w-md">
  <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
  <input id="busca" type="text" placeholder="Buscar por nome do setor..." class="w-full pl-10 pr-4 py-2.5 bg-surface-container-low border border-border-subtle rounded-lg focus:ring-2 focus:ring-primary text-body-md">
</div>

<div class="bg-surface border border-border-subtle rounded-xl overflow-hidden">
  <table class="w-full text-left border-collapse">
    <thead class="bg-background-main border-b border-border-subtle">
      <tr>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">ID</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">Nome do Setor</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase text-right">Ações</th>
      </tr>
    </thead>
    <tbody id="tbody-setores" class="divide-y divide-border-subtle">
      <tr><td colspan="3" class="px-6 py-4 text-on-surface-variant">Carregando...</td></tr>
    </tbody>
  </table>
</div>

<!-- Modal -->
<div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center modal-backdrop">
  <div class="bg-surface rounded-xl w-full max-w-md p-6">
    <h3 id="modal-titulo" class="font-headline-md text-headline-md mb-4">Adicionar Setor</h3>
    <form id="form-setor" class="space-y-4">
      <input type="hidden" id="setor-id">
      <div>
        <label class="block text-body-md font-semibold mb-1">Nome do Setor</label>
        <input id="setor-nome" required class="w-full px-4 py-2.5 border border-border-subtle rounded-lg focus:ring-2 focus:ring-primary" placeholder="Ex: Administrativo">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="fecharModal()" class="px-5 py-2.5 rounded-lg font-semibold text-on-surface-variant hover:bg-surface-container-low">Cancelar</button>
        <button type="submit" class="px-5 py-2.5 rounded-lg font-bold bg-primary text-white hover:opacity-90">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
let paginaSetores = 1;
const ITENS_POR_PAGINA = 5;
let buscaSetoresAtual = '';
async function carregarSetores(busca = buscaSetoresAtual) {
  buscaSetoresAtual = busca;
  const tbody = document.getElementById('tbody-setores');
  try {
    const todosSetores = await api('/api/setores');
    const setores = todosSetores.filter(setor => String(setor.Nome || '').toLowerCase().includes(busca.toLowerCase().trim()));
    if (!setores.length) {
      tbody.innerHTML = '<tr><td colspan="3" class="px-6 py-4 text-on-surface-variant">Nenhum setor cadastrado.</td></tr>';
      return;
    }
    const pagina = setores.slice((paginaSetores - 1) * ITENS_POR_PAGINA, paginaSetores * ITENS_POR_PAGINA);
    tbody.innerHTML = pagina.map(s => `
      <tr class="hover:bg-[#EBF2FA] transition-colors group">
        <td class="px-6 py-4 font-table-data text-table-data text-on-surface-variant">#SET-${String(s.ID).padStart(3,'0')}</td>
        <td class="px-6 py-4 font-semibold">${s.Nome}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex justify-end gap-2 opacity-60 group-hover:opacity-100">
            <button onclick='editar(${JSON.stringify(s).replace(/'/g, "&#39;")})' class="p-2 text-primary hover:bg-primary-fixed rounded"><span class="material-symbols-outlined">edit</span></button>
            <button onclick="excluir(${s.ID})" class="p-2 text-error hover:bg-error-container rounded"><span class="material-symbols-outlined">delete</span></button>
          </div>
        </td>
      </tr>`).join('');
    document.getElementById('paginacao-setores').innerHTML = htmlPaginacao(paginaSetores, setores.length, ITENS_POR_PAGINA, 'irPaginaSetores');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="3" class="px-6 py-4 text-error">${err.message}</td></tr>`;
  }
}
function irPaginaSetores(pagina) { if (pagina >= 1) { paginaSetores = pagina; carregarSetores(); } }
let debounceBuscaSetores;
document.getElementById('busca').addEventListener('input', (e) => { clearTimeout(debounceBuscaSetores); paginaSetores = 1; debounceBuscaSetores = setTimeout(() => carregarSetores(e.target.value), 250); });

function abrirModal() {
  document.getElementById('modal-titulo').textContent = 'Adicionar Setor';
  document.getElementById('setor-id').value = '';
  document.getElementById('setor-nome').value = '';
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}
function fecharModal() {
  document.getElementById('modal').classList.add('hidden');
  document.getElementById('modal').classList.remove('flex');
}
function editar(setor) {
  document.getElementById('modal-titulo').textContent = 'Editar Setor';
  document.getElementById('setor-id').value = setor.ID;
  document.getElementById('setor-nome').value = setor.Nome;
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}

document.getElementById('form-setor').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('setor-id').value;
  const nome = document.getElementById('setor-nome').value.trim();
  if (!nome) return;
  try {
    if (id) {
      await api(`/api/setores/${id}`, { method: 'PUT', body: JSON.stringify({ Nome: nome }) });
      toast('Setor atualizado com sucesso.');
    } else {
      await api('/api/setores', { method: 'POST', body: JSON.stringify({ Nome: nome }) });
      toast('Setor adicionado com sucesso.');
    }
    fecharModal();
    carregarSetores();
  } catch (err) {
    toast(err.message, 'erro');
  }
});

async function excluir(id) {
  if (!confirmarExclusao('Excluir este setor? Esta ação não pode ser desfeita.')) return;
  try {
    await api(`/api/setores/${id}`, { method: 'DELETE' });
    toast('Setor excluído.');
    carregarSetores();
  } catch (err) {
    toast(err.message, 'erro');
  }
}

carregarSetores();
</script>

<%- include('partials/foot') %>
