<% const pageTitle = 'Cadastro de Cargos'; %>
<%- include('partials/head', {pageTitle}) %>
<%- include('partials/nav', {pageTitle, active: 'cargos'}) %>

<div class="flex justify-between items-end mb-stack-lg">
  <div>
    <h3 class="font-headline-lg text-headline-lg text-on-surface">Lista de Cargos</h3>
    <p class="text-on-surface-variant font-body-md text-body-md mt-1">Gerencie as funções/cargos dos colaboradores.</p>
  </div>
  <button class="bg-primary text-white px-6 py-2.5 rounded-lg font-bold flex items-center gap-2 hover:opacity-90 transition-opacity shadow-sm" onclick="abrirModal()">
    <span class="material-symbols-outlined">add</span> Adicionar Cargo
  </button>
</div>
<div id="paginacao-cargos"></div>

<div class="bg-surface border border-border-subtle rounded-xl overflow-hidden">
  <table class="w-full text-left border-collapse">
    <thead class="bg-background-main border-b border-border-subtle">
      <tr>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">ID</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">Nome do Cargo</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase text-right">Ações</th>
      </tr>
    </thead>
    <tbody id="tbody-cargos" class="divide-y divide-border-subtle">
      <tr><td colspan="3" class="px-6 py-4 text-on-surface-variant">Carregando...</td></tr>
    </tbody>
  </table>
</div>

<div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center modal-backdrop">
  <div class="bg-surface rounded-xl w-full max-w-md p-6">
    <h3 id="modal-titulo" class="font-headline-md text-headline-md mb-4">Adicionar Cargo</h3>
    <form id="form-cargo" class="space-y-4">
      <input type="hidden" id="cargo-id">
      <div>
        <label class="block text-body-md font-semibold mb-1">Nome do Cargo</label>
        <input id="cargo-nome" required class="w-full px-4 py-2.5 border border-border-subtle rounded-lg focus:ring-2 focus:ring-primary" placeholder="Ex: Líder de Cozinha">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="fecharModal()" class="px-5 py-2.5 rounded-lg font-semibold text-on-surface-variant hover:bg-surface-container-low">Cancelar</button>
        <button type="submit" class="px-5 py-2.5 rounded-lg font-bold bg-primary text-white hover:opacity-90">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
let paginaCargos = 1;
const ITENS_POR_PAGINA = 5;
async function carregarCargos() {
  const tbody = document.getElementById('tbody-cargos');
  try {
    const cargos = await api('/api/cargos');
    if (!cargos.length) {
      tbody.innerHTML = '<tr><td colspan="3" class="px-6 py-4 text-on-surface-variant">Nenhum cargo cadastrado.</td></tr>';
      return;
    }
    const pagina = cargos.slice((paginaCargos - 1) * ITENS_POR_PAGINA, paginaCargos * ITENS_POR_PAGINA);
    tbody.innerHTML = pagina.map(c => `
      <tr class="hover:bg-[#EBF2FA] transition-colors group">
        <td class="px-6 py-4 font-table-data text-table-data text-on-surface-variant">#CAR-${String(c.ID).padStart(3,'0')}</td>
        <td class="px-6 py-4 font-semibold">${c.Nome}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex justify-end gap-2 opacity-60 group-hover:opacity-100">
            <button onclick='editar(${JSON.stringify(c).replace(/'/g, "&#39;")})' class="p-2 text-primary hover:bg-primary-fixed rounded"><span class="material-symbols-outlined">edit</span></button>
            <button onclick="excluir(${c.ID})" class="p-2 text-error hover:bg-error-container rounded"><span class="material-symbols-outlined">delete</span></button>
          </div>
        </td>
      </tr>`).join('');
    document.getElementById('paginacao-cargos').innerHTML = htmlPaginacao(paginaCargos, cargos.length, ITENS_POR_PAGINA, 'irPaginaCargos');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="3" class="px-6 py-4 text-error">${err.message}</td></tr>`;
  }
}
function irPaginaCargos(pagina) { if (pagina >= 1) { paginaCargos = pagina; carregarCargos(); } }

function abrirModal() {
  document.getElementById('modal-titulo').textContent = 'Adicionar Cargo';
  document.getElementById('cargo-id').value = '';
  document.getElementById('cargo-nome').value = '';
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}
function fecharModal() {
  document.getElementById('modal').classList.add('hidden');
  document.getElementById('modal').classList.remove('flex');
}
function editar(cargo) {
  document.getElementById('modal-titulo').textContent = 'Editar Cargo';
  document.getElementById('cargo-id').value = cargo.ID;
  document.getElementById('cargo-nome').value = cargo.Nome;
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}

document.getElementById('form-cargo').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('cargo-id').value;
  const nome = document.getElementById('cargo-nome').value.trim();
  if (!nome) return;
  try {
    if (id) {
      await api(`/api/cargos/${id}`, { method: 'PUT', body: JSON.stringify({ Nome: nome }) });
      toast('Cargo atualizado com sucesso.');
    } else {
      await api('/api/cargos', { method: 'POST', body: JSON.stringify({ Nome: nome }) });
      toast('Cargo adicionado com sucesso.');
    }
    fecharModal();
    carregarCargos();
  } catch (err) {
    toast(err.message, 'erro');
  }
});

async function excluir(id) {
  if (!confirmarExclusao('Excluir este cargo? Esta ação não pode ser desfeita.')) return;
  try {
    await api(`/api/cargos/${id}`, { method: 'DELETE' });
    toast('Cargo excluído.');
    carregarCargos();
  } catch (err) {
    toast(err.message, 'erro');
  }
}

carregarCargos();
</script>

<%- include('partials/foot') %>
