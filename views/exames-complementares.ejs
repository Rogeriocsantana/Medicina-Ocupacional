<% const pageTitle = 'Exames Complementares'; %>
<%- include('partials/head', {pageTitle}) %>
<%- include('partials/nav', {pageTitle, active: 'exames-complementares'}) %>

<div class="flex justify-between items-end mb-stack-lg">
  <div>
    <h3 class="font-headline-lg text-headline-lg text-on-surface">Exames Complementares</h3>
    <p class="text-on-surface-variant font-body-md text-body-md mt-1">Cadastre os exames que poderão ser vinculados aos cargos.</p>
  </div>
  <button class="bg-primary text-white px-6 py-2.5 rounded-lg font-bold flex items-center gap-2 hover:opacity-90 transition-opacity shadow-sm" onclick="abrirModal()">
    <span class="material-symbols-outlined">add</span> Adicionar Exame
  </button>
</div>
<div id="paginacao-exames"></div>

<div class="bg-surface border border-border-subtle rounded-xl overflow-hidden">
  <table class="w-full text-left border-collapse">
    <thead class="bg-background-main border-b border-border-subtle">
      <tr>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">ID</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">Ordem</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase">Nome</th>
        <th class="px-6 py-4 font-label-caps text-label-caps text-on-surface-variant uppercase text-right">Ações</th>
      </tr>
    </thead>
    <tbody id="tbody-exames" class="divide-y divide-border-subtle">
      <tr><td colspan="4" class="px-6 py-4 text-on-surface-variant">Carregando...</td></tr>
    </tbody>
  </table>
</div>

<div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center modal-backdrop">
  <div class="bg-surface rounded-xl w-full max-w-md p-6">
    <h3 id="modal-titulo" class="font-headline-md text-headline-md mb-4">Adicionar Exame</h3>
    <form id="form-exame" class="space-y-4">
      <input type="hidden" id="exame-id">
      <div>
        <label class="block text-body-md font-semibold mb-1">Nome</label>
        <input id="exame-nome" required class="w-full px-4 py-2.5 border border-border-subtle rounded-lg focus:ring-2 focus:ring-primary">
      </div>
      <div>
        <label class="block text-body-md font-semibold mb-1">Ordem</label>
        <input id="exame-ordem" type="number" min="1" required value="1" class="w-full px-4 py-2.5 border border-border-subtle rounded-lg focus:ring-2 focus:ring-primary">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="fecharModal()" class="px-5 py-2.5 rounded-lg font-semibold text-on-surface-variant hover:bg-surface-container-low">Cancelar</button>
        <button type="submit" class="px-5 py-2.5 rounded-lg font-bold bg-primary text-white hover:opacity-90">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
let paginaExames = 1;
const ITENS_POR_PAGINA = 5;
async function carregarExames() {
  const tbody = document.getElementById('tbody-exames');
  try {
    const exames = await api('/api/exames-complementares');
    if (!exames.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="px-6 py-4 text-on-surface-variant">Nenhum exame complementar cadastrado.</td></tr>';
      return;
    }
    const pagina = exames.slice((paginaExames - 1) * ITENS_POR_PAGINA, paginaExames * ITENS_POR_PAGINA);
    tbody.innerHTML = pagina.map(exame => `
      <tr class="hover:bg-[#EBF2FA] transition-colors group">
        <td class="px-6 py-4 font-table-data text-table-data text-on-surface-variant">#${String(exame.ID).padStart(3, '0')}</td>
        <td class="px-6 py-4">${escapeHtml(exame.Ordem)}</td>
        <td class="px-6 py-4 text-body-md">${escapeHtml(exame.Nome)}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex justify-end gap-2 opacity-60 group-hover:opacity-100">
            <button onclick='editar(${JSON.stringify(exame).replace(/'/g, "&#39;")})' class="p-2 text-primary hover:bg-primary-fixed rounded"><span class="material-symbols-outlined">edit</span></button>
            <button onclick="excluir(${exame.ID})" class="p-2 text-error hover:bg-error-container rounded"><span class="material-symbols-outlined">delete</span></button>
          </div>
        </td>
      </tr>`).join('');
    document.getElementById('paginacao-exames').innerHTML = htmlPaginacao(paginaExames, exames.length, ITENS_POR_PAGINA, 'irPaginaExames');
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-error">${escapeHtml(err.message)}</td></tr>`;
  }
}
function irPaginaExames(pagina) { if (pagina >= 1) { paginaExames = pagina; carregarExames(); } }

function abrirModal() {
  document.getElementById('modal-titulo').textContent = 'Adicionar Exame';
  document.getElementById('exame-id').value = '';
  document.getElementById('exame-nome').value = '';
  document.getElementById('exame-ordem').value = 1;
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}
function fecharModal() {
  document.getElementById('modal').classList.add('hidden');
  document.getElementById('modal').classList.remove('flex');
}
function editar(exame) {
  document.getElementById('modal-titulo').textContent = 'Editar Exame';
  document.getElementById('exame-id').value = exame.ID;
  document.getElementById('exame-nome').value = exame.Nome;
  document.getElementById('exame-ordem').value = exame.Ordem;
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal').classList.add('flex');
}

document.getElementById('form-exame').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('exame-id').value;
  const payload = {
    Nome: document.getElementById('exame-nome').value.trim(),
    Ordem: Number(document.getElementById('exame-ordem').value) || 1
  };
  try {
    if (id) await api(`/api/exames-complementares/${id}`, { method: 'PUT', body: JSON.stringify(payload) });
    else await api('/api/exames-complementares', { method: 'POST', body: JSON.stringify(payload) });
    fecharModal();
    toast('Exame complementar salvo.');
    carregarExames();
  } catch (err) {
    toast(err.message, 'erro');
  }
});

async function excluir(id) {
  if (!confirmarExclusao('Excluir este exame complementar? Remova antes os vínculos com cargos.')) return;
  try {
    await api(`/api/exames-complementares/${id}`, { method: 'DELETE' });
    toast('Exame complementar excluído.');
    carregarExames();
  } catch (err) {
    toast(err.message, 'erro');
  }
}

carregarExames();
</script>

<%- include('partials/foot') %>
