<script>
// ---- Helpers compartilhados (carregados antes de qualquer script de página) ----
async function api(url, options = {}) {
  const res = await fetch(url, {
    headers: { 'Content-Type': 'application/json' },
    cache: 'no-store',
    ...options
  });
  let data = null;
  try { data = await res.json(); } catch (e) { /* sem corpo */ }
  if (!res.ok) {
    const msg = (data && data.erro) ? data.erro : `Erro na requisição (${res.status})`;
    throw new Error(msg);
  }
  return data;
}

function toast(mensagem, tipo = 'sucesso') {
  const container = document.getElementById('toast-container');
  if (!container) return alert(mensagem);
  const bg = tipo === 'erro' ? 'bg-error text-white' : 'bg-primary text-white';
  const el = document.createElement('div');
  el.className = `${bg} px-4 py-3 rounded-lg shadow-lg font-body-md text-body-md max-w-sm`;
  el.textContent = mensagem;
  container.appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

function confirmarExclusao(mensagem) {
  return window.confirm(mensagem || 'Tem certeza que deseja excluir este registro?');
}

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function onlyDigits(value) {
  return String(value || '').replace(/\D/g, '');
}

function formatCpf(value) {
  const d = onlyDigits(value).slice(0, 11);
  if (d.length <= 3) return d;
  if (d.length <= 6) return d.slice(0, 3) + '.' + d.slice(3);
  if (d.length <= 9) return d.slice(0, 3) + '.' + d.slice(3, 6) + '.' + d.slice(6);
  return d.slice(0, 3) + '.' + d.slice(3, 6) + '.' + d.slice(6, 9) + '-' + d.slice(9);
}

function isValidCpf(value) {
  const cpf = onlyDigits(value);
  if (cpf.length !== 11) return false;
  if (/^(\d)\1{10}$/.test(cpf)) return false;
  let sum = 0;
  for (let i = 0; i < 9; i++) sum += Number(cpf[i]) * (10 - i);
  let rest = (sum * 10) % 11;
  if (rest === 10) rest = 0;
  if (rest !== Number(cpf[9])) return false;
  sum = 0;
  for (let i = 0; i < 10; i++) sum += Number(cpf[i]) * (11 - i);
  rest = (sum * 10) % 11;
  if (rest === 10) rest = 0;
  return rest === Number(cpf[10]);
}

function bindCpfMask(input) {
  if (!input) return;
  input.setAttribute('inputmode', 'numeric');
  input.setAttribute('maxlength', '14');
  input.setAttribute('autocomplete', 'off');
  input.addEventListener('input', () => {
    const start = input.selectionStart;
    const before = input.value.length;
    input.value = formatCpf(input.value);
    const after = input.value.length;
    if (typeof start === 'number') {
      const next = Math.max(0, start + (after - before));
      try { input.setSelectionRange(next, next); } catch (_) {}
    }
  });
}

async function downloadPdfFromResponse(res, fallbackName = 'ASO.pdf') {
  if (!res.ok) {
    let data = null;
    try { data = await res.json(); } catch (_) {}
    throw new Error((data && data.erro) || `Erro na requisição (${res.status})`);
  }
  const disposition = res.headers.get('Content-Disposition') || '';
  const match = disposition.match(/filename="?([^"]+)"?/i);
  const filename = match ? match[1] : fallbackName;
  const blob = await res.blob();
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}
</script>
