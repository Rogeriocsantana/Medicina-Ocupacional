<body class="bg-background-main text-on-surface">
<aside class="fixed left-0 top-0 h-full flex flex-col pt-4 pb-8 overflow-y-auto z-40 bg-surface border-r border-border-subtle w-sidebar-width">
  <div class="px-6 mb-8">
    <div class="flex items-center gap-3">
      <img src="/public/images/logo-icone.jpg" alt="Santa Tereza" class="h-11 w-11 rounded-lg object-contain bg-white p-1 border border-border-subtle">
      <div class="flex flex-col">
        <h1 class="text-headline-md font-headline-md font-bold text-primary leading-tight">Clínica Pierro</h1>
        <p class="text-on-surface-variant text-[11px] tracking-wider uppercase font-bold mt-1">Gestão Ocupacional</p>
      </div>
    </div>
  </div>
  <nav class="flex-1 px-3 space-y-1">
    <% const links = [
      { href: '/', icon: 'dashboard', label: 'Dashboard', key: 'dashboard' },
      { href: '/setores', icon: 'domain', label: 'Setores', key: 'setores' },
      { href: '/cargos', icon: 'work', label: 'Cargos', key: 'cargos' },
      { href: '/funcionarios', icon: 'badge', label: 'Funcionários', key: 'funcionarios' },
      { href: '/riscos', icon: 'warning', label: 'Riscos', key: 'riscos' },
      { href: '/exames-complementares', icon: 'biotech', label: 'Exames Complementares', key: 'exames-complementares' },
      { href: '/relacionamento', icon: 'account_tree', label: 'Relacionamento', key: 'relacionamento' },
      { href: '/historico', icon: 'history', label: 'Histórico', key: 'historico' }
    ]; %>
    <% links.forEach(l => { %>
      <a href="<%= l.href %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-body-md text-body-md transition-all <%= active === l.key ? 'bg-secondary-container text-primary font-bold shadow-sm' : 'text-on-surface-variant hover:bg-surface-container-low' %>">
        <span class="material-symbols-outlined" style="<%= active === l.key ? "font-variation-settings: 'FILL' 1;" : '' %>"><%= l.icon %></span>
        <span><%= l.label %></span>
      </a>
    <% }) %>
  </nav>
  <div class="px-4 mt-6">
    <a href="/gerar-pdf" class="w-full py-3 px-4 bg-primary text-white font-bold rounded-lg hover:opacity-90 transition-opacity flex items-center justify-center gap-2">
      <span class="material-symbols-outlined text-sm">picture_as_pdf</span>
      Gerar Novo PDF
    </a>
  </div>
</aside>

<main class="ml-sidebar-width flex flex-col min-h-screen">
  <header class="flex justify-between items-center w-full px-gutter h-16 sticky top-0 z-30 bg-surface border-b border-border-subtle">
    <div>
      <h2 class="font-headline-md text-headline-md font-bold text-primary"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h2>
    </div>
    <div class="flex items-center gap-3">
      <a href="/configuracoes" title="Configurações" class="p-2 rounded-full transition-colors <%= active === 'configuracoes' ? 'bg-secondary-container text-primary' : 'text-on-surface-variant hover:bg-surface-container-low' %>">
        <span class="material-symbols-outlined">settings</span>
      </a>
      <div class="flex items-center gap-2 pl-3 border-l border-border-subtle">
        <span class="hidden md:block text-right leading-tight"><span id="nav-medico" class="block text-body-md font-bold text-on-surface">Médico coordenador</span><span id="nav-especialidade" class="block text-[11px] text-on-surface-variant">Medicina do Trabalho</span></span>
        <span title="Médico coordenador" class="w-9 h-9 rounded-full bg-primary-fixed text-primary flex items-center justify-center border border-primary-fixed-dim">
          <span class="material-symbols-outlined">medical_services</span>
        </span>
      </div>
    </div>
  </header>
  <div id="toast-container" class="fixed top-20 right-6 z-50 space-y-2"></div>
  <div class="p-gutter flex-1">

<script>
api('/api/config').then(config => {
  const medico = document.getElementById('nav-medico');
  const especialidade = document.getElementById('nav-especialidade');
  if (medico && config.Medico) medico.textContent = config.Medico;
  if (especialidade && config.Especialidade) especialidade.textContent = config.Especialidade;
}).catch(() => {});
</script>
