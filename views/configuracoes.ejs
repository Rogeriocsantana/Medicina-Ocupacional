<% const pageTitle = 'Configurações'; %>
<%- include('partials/head', {pageTitle}) %>
<%- include('partials/nav', {pageTitle, active: 'configuracoes'}) %>

<div class="mb-stack-lg">
  <h3 class="font-headline-lg text-headline-lg text-on-surface">Configurações do ASO</h3>
  <p class="text-on-surface-variant text-body-md mt-1">Administre os dados institucionais, médico responsável e tipos de exame.</p>
  <div class="inline-flex flex-wrap mt-5 bg-surface-container p-1 rounded-xl border border-border-subtle gap-1">
    <button onclick="mostrarAbaConfig('clinica')" data-aba="clinica" class="aba-config px-4 py-2 bg-surface text-primary font-bold rounded-lg shadow-sm text-body-md">Dados da clínica</button>
    <button onclick="mostrarAbaConfig('medico')" data-aba="medico" class="aba-config px-4 py-2 text-on-surface-variant font-semibold rounded-lg text-body-md">Médico</button>
    <button onclick="mostrarAbaConfig('tipos')" data-aba="tipos" class="aba-config px-4 py-2 text-on-surface-variant font-semibold rounded-lg text-body-md">Tipos de exame</button>
  </div>
</div>

<form id="form-config" class="max-w-5xl">
  <section id="painel-clinica" class="painel-config bg-surface border border-border-subtle rounded-xl p-6 space-y-6">
    <div class="flex items-center gap-3 border-b border-border-subtle pb-4"><span class="material-symbols-outlined text-primary">business</span><div><h4 class="font-headline-md">Dados da empresa</h4><p class="text-body-md text-on-surface-variant">Informações exibidas no cabeçalho do ASO.</p></div></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2"><label class="block text-body-md font-semibold mb-1">Razão social</label><input id="RazaoSocial" required class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">CNPJ</label><input id="CNPJ" required class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">Telefone</label><input id="Telefone" class="campo"></div>
      <div class="md:col-span-2"><label class="block text-body-md font-semibold mb-1">Endereço</label><input id="Endereco" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">Bairro</label><input id="Bairro" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">Cidade/UF</label><input id="CidadeUf" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">CEP</label><input id="Cep" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">Nome no cabeçalho</label><input id="HospitalNome" class="campo"></div>
    </div>
  </section>

  <section id="painel-medico" class="painel-config hidden bg-surface border border-border-subtle rounded-xl p-6 space-y-6">
    <div class="flex items-center gap-3 border-b border-border-subtle pb-4"><span id="preview-icone-medico" class="w-10 h-10 rounded-full bg-primary-fixed text-primary flex items-center justify-center"><span class="material-symbols-outlined">medical_services</span></span><div><h4 class="font-headline-md">Médico coordenador</h4><p class="text-body-md text-on-surface-variant">Esses dados aparecem no cabeçalho da aplicação e no ASO.</p></div></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2"><label class="block text-body-md font-semibold mb-1">Médico</label><input id="Medico" required class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">CRM</label><input id="CRM" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">Especialidade</label><input id="Especialidade" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-1">RQE</label><input id="RQE" class="campo"></div>
      <div><label class="block text-body-md font-semibold mb-2">Ícone do médico</label><input id="IconeMedico" type="hidden" value="medical_services"><div id="opcoes-icone-medico" class="flex flex-wrap gap-2"><button type="button" data-icone="medical_services" onclick="selecionarIconeMedico('medical_services')" title="Serviços médicos" class="opcao-icone-medico"><span class="material-symbols-outlined">medical_services</span></button><button type="button" data-icone="stethoscope" onclick="selecionarIconeMedico('stethoscope')" title="Estetoscópio" class="opcao-icone-medico"><span class="material-symbols-outlined">stethoscope</span></button><button type="button" data-icone="health_and_safety" onclick="selecionarIconeMedico('health_and_safety')" title="Saúde e segurança" class="opcao-icone-medico"><span class="material-symbols-outlined">health_and_safety</span></button><button type="button" data-icone="clinical_notes" onclick="selecionarIconeMedico('clinical_notes')" title="Prontuário clínico" class="opcao-icone-medico"><span class="material-symbols-outlined">clinical_notes</span></button><button type="button" data-icone="cardiology" onclick="selecionarIconeMedico('cardiology')" title="Cardiologia" class="opcao-icone-medico"><span class="material-symbols-outlined">cardiology</span></button></div></div>
    </div>
  </section>

  <div class="flex justify-end mt-5"><button type="submit" class="bg-primary text-white px-6 py-2.5 rounded-lg font-bold">Salvar configurações</button></div>
</form>

<section id="painel-tipos" class="painel-config hidden max-w-5xl bg-surface border border-border-subtle rounded-xl p-6 space-y-4">
  <div class="flex justify-between items-center"><div><h4 class="font-headline-md">Tipos de exame</h4><p class="text-body-md text-on-surface-variant">Opções apresentadas na emissão do ASO.</p></div><button onclick="abrirModalTipo()" class="bg-primary text-white px-4 py-2 rounded-lg font-bold">Adicionar</button></div>
  <table class="w-full text-left"><thead class="border-b border-border-subtle"><tr><th class="py-2 text-label-caps uppercase">Ordem</th><th class="py-2 text-label-caps uppercase">Chave</th><th class="py-2 text-label-caps uppercase">Nome</th><th class="py-2 text-right text-label-caps uppercase">Ações</th></tr></thead><tbody id="tbody-tipos"></tbody></table>
</section>

<div id="modal-tipo" class="fixed inset-0 z-50 hidden items-center justify-center modal-backdrop"><div class="bg-surface rounded-xl w-full max-w-md p-6"><h3 id="modal-tipo-titulo" class="font-headline-md mb-4">Tipo de exame</h3><form id="form-tipo" class="space-y-4"><input type="hidden" id="tipo-id"><div><label class="block font-semibold mb-1">Chave</label><input id="tipo-chave" required class="campo"></div><div><label class="block font-semibold mb-1">Nome</label><input id="tipo-nome" required class="campo"></div><div><label class="block font-semibold mb-1">Ordem</label><input id="tipo-ordem" type="number" min="1" required value="1" class="campo"></div><div class="flex justify-end gap-3"><button type="button" onclick="fecharModalTipo()" class="px-4 py-2">Cancelar</button><button class="px-4 py-2 bg-primary text-white rounded-lg font-bold">Salvar</button></div></form></div></div>

<style>.campo{width:100%;padding:.625rem .75rem;border:1px solid #DEE2E6;border-radius:.5rem}.campo:focus{outline:2px solid #00478d;outline-offset:1px}.opcao-icone-medico{width:42px;height:42px;border:1px solid #DEE2E6;border-radius:.5rem;color:#424752}.opcao-icone-medico:hover,.opcao-icone-medico.ativo{background:#dce8f8;border-color:#00478d;color:#00478d}</style>
<script>
const CONFIG_FIELDS=['RazaoSocial','CNPJ','Endereco','Bairro','CidadeUf','Cep','Telefone','HospitalNome','Medico','CRM','Especialidade','RQE','IconeMedico'];
function mostrarAbaConfig(aba){document.querySelectorAll('.painel-config').forEach(p=>p.classList.toggle('hidden',p.id!==`painel-${aba}`));document.querySelectorAll('.aba-config').forEach(b=>b.className=`aba-config px-4 py-2 rounded-lg text-body-md ${b.dataset.aba===aba?'bg-surface text-primary font-bold shadow-sm':'text-on-surface-variant font-semibold'}`)}
function atualizarPreviewIcone(){const icone=document.getElementById('IconeMedico').value;document.querySelector('#preview-icone-medico .material-symbols-outlined').textContent=icone;document.querySelectorAll('.opcao-icone-medico').forEach(botao=>botao.classList.toggle('ativo',botao.dataset.icone===icone))}function selecionarIconeMedico(icone){document.getElementById('IconeMedico').value=icone;atualizarPreviewIcone()}
async function carregarConfig(){const cfg=await api('/api/config');CONFIG_FIELDS.forEach(f=>{const el=document.getElementById(f);if(el)el.value=cfg[f]||''});atualizarPreviewIcone()}
document.getElementById('form-config').addEventListener('submit',async e=>{e.preventDefault();const payload={};CONFIG_FIELDS.forEach(f=>payload[f]=document.getElementById(f).value.trim());try{await api('/api/config',{method:'PUT',body:JSON.stringify(payload)});toast('Configurações salvas.')}catch(err){toast(err.message,'erro')}});
async function carregarTipos(){const rows=await api('/api/tipos-exame');document.getElementById('tbody-tipos').innerHTML=rows.map(r=>`<tr class="border-b border-border-subtle"><td class="py-3">${escapeHtml(r.Ordem)}</td><td>${escapeHtml(r.Chave)}</td><td>${escapeHtml(r.Nome)}</td><td class="text-right"><button onclick='editarTipo(${JSON.stringify(r)})' class="p-2 text-primary hover:bg-primary-fixed rounded" title="Editar"><span class="material-symbols-outlined">edit</span></button><button onclick="excluirTipo(${r.ID})" class="p-2 text-error hover:bg-error-container rounded" title="Excluir"><span class="material-symbols-outlined">delete</span></button></td></tr>`).join('')||'<tr><td colspan="4" class="py-3 text-on-surface-variant">Nenhum tipo cadastrado.</td></tr>'}
function abrirModalTipo(r){document.getElementById('modal-tipo').classList.replace('hidden','flex');['id','chave','nome','ordem'].forEach(x=>document.getElementById(`tipo-${x}`).value=r?({id:r.ID,chave:r.Chave,nome:r.Nome,ordem:r.Ordem}[x]):(x==='ordem'?1:''));document.getElementById('modal-tipo-titulo').textContent=r?'Editar tipo':'Novo tipo'}function fecharModalTipo(){document.getElementById('modal-tipo').classList.replace('flex','hidden')}function editarTipo(r){abrirModalTipo(r)}
document.getElementById('form-tipo').addEventListener('submit',async e=>{e.preventDefault();const id=document.getElementById('tipo-id').value,p={Chave:document.getElementById('tipo-chave').value.trim().toLowerCase().replace(/\s+/g,'_'),Nome:document.getElementById('tipo-nome').value.trim(),Ordem:Number(document.getElementById('tipo-ordem').value)||1};try{await api(id?`/api/tipos-exame/${id}`:'/api/tipos-exame',{method:id?'PUT':'POST',body:JSON.stringify(p)});fecharModalTipo();carregarTipos();toast('Tipo salvo.')}catch(err){toast(err.message,'erro')}});async function excluirTipo(id){if(confirmarExclusao())try{await api(`/api/tipos-exame/${id}`,{method:'DELETE'});carregarTipos()}catch(err){toast(err.message,'erro')}}
Promise.all([carregarConfig(),carregarTipos()]).catch(err=>toast(err.message,'erro'));
</script>
<%- include('partials/foot') %>
